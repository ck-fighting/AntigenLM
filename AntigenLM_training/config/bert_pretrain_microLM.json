{
    "name": "microLM_pretrain",
    "n_gpu": 2,
    "pretrained_model_path": "",
    "dataset": {
        "type": "MAADataset",
        "args": {
            "seq_dir": "../dataset/dataset_micro.fasta",
            "token_length_list": "2,3",
            "vocab_dir": "../bert_data_prepare/microorganism-2-3.csv",
            "seed": 0,
            "seq_name": "dataset_micro",
            "tokenizer_name": "common",
            "max_len": 256,
            "test_split": 0.001
        }
    },
    "model": {
        "bert": "roformer",
        "args": {
            "hidden_size": 768,
            "num_hidden_layers": 32,
            "num_attention_heads": 32,
            "intermediate_size": 3072,
            "hidden_act": "gelu",
            "hidden_dropout_prob": 0.1,
            "attention_probs_dropout_prob": 0.1,
            "max_position_embeddings": 512,
            "type_vocab_size": 3,
            "initializer_range": 0.01,
            "position_embedding_type": "absolute"
        }
    },
    "metrics": {
        "blosum_dir": "../bert_data_prepare/blosum62.json",
        "blosum": true
    },
    "trainer": {
        "epochs": 20,
        "batch_size": 256,
        "save_dir": "../../LLM/MicroLM_300M",
        "lr": 5e-05,
        "warmup": 0.1,
        "weight_decay": 0.01,
        "eval_accumulation_steps": 64,
        "logging_steps": 500
    },
    "deepspeed": {
        "train_micro_batch_size_per_gpu": 256,
        "gradient_accumulation_steps": 1,
        "deepspeed_communication_data": {
            "CUDA_VISIBLE_DEVICES": "1,2"
        },
        "deepspeed_multinode_launcher": "standard",
        "optimizer": {
            "type": "AdamW",
            "params": {
                "lr": "auto",
                "weight_decay": "auto"
            }
        },
        "fp16": {
            "enabled": true
        },
        "zero_optimization": {
            "stage": 2,
            "overlap_comm": true,
            "stage3_gather_16bit_weights_on_model_save": true
        },
        "gradient_clipping": 1.0,
        "steps_per_print": 2000,
        "wall_clock_breakdown": true
    }
}